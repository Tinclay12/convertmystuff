# Public environment variables (embedded in client bundles — never put secrets here)

# Required in production: canonical site URL for sitemap, OG, and metadata
NEXT_PUBLIC_SITE_URL=https://convertmystuff.com

# Optional: Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# NEXT_PUBLIC_ANALYTICS_ID=

# Optional: search engine verification meta tags
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_BING_VERIFICATION=
# NEXT_PUBLIC_YANDEX_VERIFICATION=
# NEXT_PUBLIC_YAHOO_VERIFICATION=
